{
  "$schema" : "https://raw.githubusercontent.com/manaflow-ai/cmux/main/web/data/cmux.schema.json",
  "schemaVersion" : 1,
  "shortcuts": {
    "bindings": {
      "toggleTerminalCopyMode": ["ctrl+a", "m"],
      "newSurface": "cmd+t",
      "toggleSidebar": ["ctrl+a", "w"],
      "focusRightSidebar": ["ctrl+a", "i"],
      "openDiffViewer": ["ctrl+a", "d"],      
      "toggleFileExplorer": ["ctrl+a", "e"],
      "focusLeft": "cmd+h",
      "focusRight": "cmd+l",
      "focusUp": "cmd+k",
      "focusDown": "cmd+j",
      "newTab": "cmd+n",
      "nextSidebarTab": "cmd+shift+j",
      "prevSidebarTab": "cmd+shift+k",
      "nextSurface": "cmd+shift+l",
      "prevSurface": "cmd+shift+h",
      "triggerFlash": ["ctrl+a", "f"],
      "commandPalette": "cmd+p",
      "jumpToUnread": ["ctrl+a", "u"],
      "splitRight": ["ctrl+a", "v"],
      "splitDown": ["ctrl+a", "s"],
      "toggleSplitZoom": ["ctrl+a", "z"],
      "openBrowser": ["ctrl+a", "b"]
    }
  }
}
